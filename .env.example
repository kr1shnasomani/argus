# =============================================================================
# Argus — Environment Configuration
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Supabase ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-db-password

# --- Qdrant Cloud ---
QDRANT_URL=https://your-cluster-url.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=resolved_tickets

# --- Jina AI ---
JINA_API_KEY=your-jina-api-key

# --- LLM (primary: OpenRouter → fallback: Groq → fallback: Gemini) ---
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemma-3-27b-it:free

GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

GOOGLE_GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# --- Sandbox Server ---
SANDBOX_URL=http://localhost:8001

# --- Default Confidence Thresholds (overridden per-category in DB) ---
DEFAULT_THRESHOLD_A=0.85
DEFAULT_THRESHOLD_B=0.60
DEFAULT_THRESHOLD_C=0.70
DEFAULT_NOVELTY_THRESHOLD=0.50
DEFAULT_MIN_SAMPLE_SIZE=30
